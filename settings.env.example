# Required account and PostgreSQL settings. In production, store these as
# sensitive Octopus variables rather than committing a settings.env file.
POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=imdb_rapid_rater;Username=rapid_rater;Password=replace-me
RAPID_RATER_DB_SCHEMA=imdb_rapid_rater
SESSION_SECRET=replace-with-at-least-32-random-characters
DATA_ENCRYPTION_KEY=replace-with-output-from-npm-run-key-generate
# Encryption rollout modes:
# legacy = existing local key only
# dual = Azure Key Vault writes plus legacy reads during migration
# vault = Azure Key Vault only after every legacy record is migrated
SECRET_PROTECTION_MODE=legacy
# Azure vault origin used to load PostgreSQL, session, and TMDB secrets.
AZURE_KEY_VAULT_URL=
# Full Azure Key Vault key identifier, including the key name. This is not a secret.
AZURE_KEY_VAULT_KEY_ID=
# Production uses the VM managed identity. Set only for a user-assigned identity.
AZURE_MANAGED_IDENTITY_CLIENT_ID=
APP_ORIGIN=http://localhost:5012
# Optional comma-separated browser origins in addition to APP_ORIGIN.
APP_ALLOWED_ORIGINS=
# Optional exact origins for private-network or HTTP AI servers.
AI_ALLOWED_PRIVATE_ORIGINS=
TRUST_PROXY_HOPS=1
PUBLIC_REGISTRATION_ENABLED=true

# Optional: set true to test the UI/server path without sending anything to IMDb.
IMDB_DRY_RUN=false
IMDB_MAX_REQUESTS_PER_SECOND=10
IMDB_WORKER_CONCURRENCY=4

# IMDb connection data, AI API keys, imported ratings, and progress are stored per
# account in PostgreSQL. In dual/vault mode, credentials use per-user envelope
# encryption and the non-exportable wrapping key identified above.
# Server-owned TMDB credential used for shared metadata and streaming caches.
TMDB_API_KEY=
# Build-only TMDB credential used by npm run build:origins. Origin lookup results
# are stored in PostgreSQL using POSTGRES_CONNECTION_STRING above.
TMDB_BUILD_API_KEY=
TMDB_ORIGIN_CONCURRENCY=12
