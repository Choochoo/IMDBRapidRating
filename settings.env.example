# Optional manual settings file for IMDb Rapid Rater.
# The app normally writes settings.env inside your user-data folder.
# You can also set these names as shell environment variables before npm start.
#
# Default user-data folders:
# Windows: %APPDATA%\IMDb Rapid Rater
# macOS: ~/Library/Application Support/IMDb Rapid Rater
# Linux: ${XDG_DATA_HOME:-~/.local/share}/imdb-rapid-rater

# Paste the full value from Chrome DevTools Network -> Request Headers -> Cookie.
# Either form is accepted:
# IMDB_COOKIE=<paste the full Cookie request-header value here>
# IMDB_COOKIE=Cookie: <paste the full Cookie request-header value here>
IMDB_COOKIE=

# Optional: set true to test the UI/server path without sending anything to IMDb.
IMDB_DRY_RUN=false

# Optional but recommended for reliable posters and synopsis text.
# Create a TMDB API key at https://developer.themoviedb.org/reference/getting-started
TMDB_API_KEY=

# Optional: required for AI recommendations.
OPENAI_API_KEY=
# Optional override. Leave blank to auto-select from OpenAI's Models API.
OPENAI_MODEL=
OPENAI_MODEL_LAG=2
