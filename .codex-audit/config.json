{
  "audit_mode": "change",
  "change_paths": [
    ".github/workflows/deploy-octopus.yml",
    "README.md",
    "index.html",
    "scripts/enrich-title-origins.mjs",
    "server/db/schema.mjs",
    "server/routes.mjs",
    "server/title-metadata.mjs",
    "src/app/features/catalog-view.js",
    "src/app/rendering.js",
    "src/styles/rater.css",
    "src/styles/responsive.css",
    "test/recommendation-rendering.test.mjs",
    "test/title-metadata.test.mjs",
    "db/migrations/0008_title_metadata_cache.sql",
    "server/streaming-availability.mjs",
    "server/title-metadata-store.mjs",
    "test/streaming-availability.test.mjs",
    "test/title-metadata-store.test.mjs"
  ],
  "default_batch_limit": 20,
  "exclude_globs": [
    ".codex-audit/**",
    ".codex/project-intelligence/**",
    ".codex/agents/project-knowledge-reviewer.toml",
    "docs/project-knowledge/**",
    ".git/**",
    "node_modules/**",
    "vendor/**",
    "vendors/**",
    "dist/**",
    "build/**",
    "out/**",
    "target/**",
    ".next/**",
    ".nuxt/**",
    ".cache/**",
    "__pycache__/**",
    "*.min.js",
    "*.map",
    "*.lock",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock"
  ],
  "exclude_roots": [],
  "include_roots": [],
  "include_untracked": true,
  "remediation_strategy": "rule_order",
  "require_final_review_for_dirty_diff": true,
  "require_reviewer_for_passed_checks": true,
  "validation_commands": [],
  "validation_timeout_seconds": 120,
  "version": 2,
  "workflow_mode": "remediation"
}
