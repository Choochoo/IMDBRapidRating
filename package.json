{
  "name": "imdb-rapid-rater",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "scripts": {
    "start": "node scripts/server.mjs",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/migrate.mjs",
    "db:sync-permissions": "node scripts/sync-database-permissions.mjs",
    "user:create": "node scripts/create-user.mjs",
    "key:generate": "node scripts/generate-key.mjs",
    "build:data": "node scripts/build-movie-pool.mjs --minVotes=2500 --recentMinVotes=100 --recentYears=1",
    "build:origins": "node scripts/enrich-title-origins.mjs",
    "check": "node scripts/check-syntax.mjs && npm run typecheck",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "bootstrap": "^5.3.8",
    "connect-pg-simple": "^10.0.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "fflate": "^0.8.3",
    "helmet": "^8.3.0",
    "lucide": "^1.26.0",
    "pg": "^8.22.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "supertest": "^7.2.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
